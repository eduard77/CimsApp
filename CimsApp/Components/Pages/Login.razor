@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout EmptyLayout
@inject UiStateService UI
@inject AuthService AuthSvc
@inject NavigationManager Nav
<div style="min-height:100vh;background:linear-gradient(135deg,#1B2B4B 0%,#1B4F8A 100%);display:flex;align-items:center;justify-content:center;">
    <div style="width:100%;max-width:420px;padding:24px;">
        <div style="text-align:center;margin-bottom:40px;">
            <div style="width:64px;height:64px;background:#F5A623;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <MudIcon Icon="@Icons.Material.Filled.Domain" Style="color:#1B2B4B;font-size:32px;" />
            </div>
            <h1 style="color:white;font-size:28px;font-weight:700;margin:0;">CIMS</h1>
            <p style="color:rgba(255,255,255,0.5);font-size:12px;margin:4px 0 0;letter-spacing:1px;text-transform:uppercase;">Construction Information Management</p>
        </div>

        <MudCard Elevation="0" Style="border-radius:16px;">
            <MudCardContent Style="padding:36px;">
                <h2 style="font-size:20px;font-weight:600;margin:0 0 4px;">Sign in</h2>
                <p style="color:#64748B;font-size:14px;margin:0 0 28px;">Enter your credentials to continue</p>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Style="margin-bottom:20px;border-radius:8px;">@_error</MudAlert>
                }

                <MudTextField @bind-Value="_email" Label="Email address" Variant="Variant.Outlined"
                              InputType="InputType.Email" FullWidth="true" Margin="Margin.Dense"
                              Style="margin-bottom:16px;" Disabled="_loading" />

                <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                              InputType="@(_showPw? InputType.Text: InputType.Password)"
                              FullWidth="true" Margin="Margin.Dense" Style="margin-bottom:28px;"
                              Disabled="_loading" Adornment="Adornment.End"
                              AdornmentIcon="@(_showPw? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showPw = !_showPw" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="LoginAsync" Disabled="_loading"
                           Style="height:48px;border-radius:10px;font-size:15px;font-weight:600;text-transform:none;">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="margin-right:8px;" />
                        <span>Signing in...</span>
 }
                    else
                    {
                        <span>Sign in</span>
                    }
                </MudButton>
            </MudCardContent>
        </MudCard>
        <p style="text-align:center;color:rgba(255,255,255,0.3);font-size:12px;margin-top:24px;">ISO 19650 · PMBOK 7th Edition</p>
    </div>
</div>

@code {
    string _email = "", _password = "", _error = "";
    bool _loading = false, _showPw = false;

    protected override void OnInitialized()
    {
        if (UI.IsLoggedIn) Nav.NavigateTo("/dashboard");
    }

    async Task LoginAsync()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter your email and password.";
            return;
        }

        _loading = true;
        try
        {
            var result = await AuthSvc.LoginAsync(
                new CimsApp.DTOs.LoginRequest(_email, _password), null, null);

            UI.SetLogin(
                result.AccessToken,
                result.User.Id,
                result.User.FirstName,
                result.User.LastName,
                result.User.Organisation.Name);

            Nav.NavigateTo("/dashboard");
        }
        catch (CimsApp.Core.AppException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}