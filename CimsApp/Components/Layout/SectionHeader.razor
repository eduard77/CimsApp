@* SectionHeader.razor — numbered step heading *@
<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <div style="width:28px;height:28px;border-radius:50%;background:#1B4F8A;color:white;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;">
        @StepNumber
    </div>
    <div>
        <p style="font-size:15px;font-weight:600;color:#1A1F2E;margin:0;">@Title</p>
        <p style="font-size:12px;color:#94A3B8;margin:0;">@Subtitle</p>
    </div>
</div>

@code {
    [Parameter] public int    StepNumber { get; set; }
    [Parameter] public string Title      { get; set; } = "";
    [Parameter] public string Subtitle   { get; set; } = "";
}
